# creatorgrowth — environment template
# Copy to .env on the VPS (NEVER check the real .env in).

# ── Session signing (must be permanent, in 1Password) ──────────────
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'
# If unset, the app generates one per process start — every restart kicks
# every user out and invalidates pending DM-codes. MUST be pinned in prod.
SECRET_KEY=

# ── Legacy email login (Andy admin backdoor) ───────────────────────
DASHBOARD_PASSWORD=

# ── DB path override (default: ./videos.db) ────────────────────────
# DB_PATH=/opt/idea_dashboard/videos.db

# ── Self-host open mode ────────────────────────────────────────────
# Set OPEN_SIGNUP=1 if you are running your OWN copy (cloned from GitHub).
# It disables the Skool gate entirely: any email that signs in gets
# permanent, full access — no 7-day trial, no day-7 auto-revoke, and the
# "Join AI Mate" CTAs are hidden. If you have no email provider configured
# (RESEND_API_KEY below), the 6-digit login code is shown on the login
# screen (and printed to the container logs) so you can still sign in.
# Leave UNSET for the hosted creatorgrowth.com Skool-membership model.
OPEN_SIGNUP=

# ── External APIs ──────────────────────────────────────────────────
YOUTUBE_API_KEY=
BLOTATO_API_KEY=
BLOTATO_X_ACCOUNT_ID=13469
AIRTABLE_TOKEN=
NAS_UPLOAD_URL=https://media.agentflow.net/upload

# ── Skool OAuth (set ALL three to disable mock mode) ───────────────
# Per project_creatorgrowth_skool_auth memory: Skool exposes no public OAuth
# today. These stay unset; auth uses the DM-code path instead. If Skool
# ever ships an OAuth flow, fill these in and the /api/auth/skool/callback
# stops accepting `user_email` and only accepts real OAuth codes.
SKOOL_API_KEY=
SKOOL_CLIENT_ID=
SKOOL_CLIENT_SECRET=
SKOOL_REDIRECT_URI=https://creatorgrowth.com/api/auth/skool/oauth-redirect
# Optional URL overrides (defaults are reasonable):
# SKOOL_AUTH_URL=https://www.skool.com/oauth/authorize
# SKOOL_TOKEN_URL=https://www.skool.com/oauth/token
# SKOOL_MEMBER_URL=https://www.skool.com/api/v1/member/me

# ── DM-code flow (legacy / emergency override) ─────────────────────
# Default auth path is now email-based activation (see /api/auth/skool/activate);
# DM-code is retained for high-trust manual verification only.
# The handle members are told to DM with their 6-digit code.
SKOOL_DM_TARGET=theaiandy
# How long codes are valid before expiring.
DM_CODE_TTL_SEC=600
# Shared secret the Chrome ext / CLI uses to call
# /api/auth/skool/dm-code/admin-verify. Generate with the same recipe as
# SECRET_KEY. Required for admin-verify; without it that route 503s.
DM_VERIFY_TOKEN=

# ── Paid-member webhook (Zapier new_paid_member → CG) ──────────────
# Bearer token Zapier sends to /api/admin/paid-members. UPSERTs the user
# row with allowlist_source='paid'. Generate fresh per environment:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# Required for the webhook; without it that route 503s.
PAID_WEBHOOK_TOKEN=

# ── Magic-code email login (default user-facing auth) ──────────────
# When set, typing this value into the "code" field of /activate bypasses
# email-code verification. For dev/test only — leave EMPTY in prod once
# real email sending is wired. With this empty, real codes from email are
# the only way in.
ADMIN_LOGIN_PASSWORD=
# Code TTL in seconds (default 600 = 10 min).
LOGIN_CODE_TTL_SEC=600
# Resend (resend.com) — transactional email provider. With this set, codes go
# out via the Resend HTTP API. Without it, codes are only logged to stderr
# (dev mode). Sign up at resend.com → verify domain → API Keys → create one.
RESEND_API_KEY=
RESEND_FROM=CreatorGrowth <login@creatorgrowth.com>
# Legacy SMTP placeholders (unused — kept for env compatibility).
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=login@creatorgrowth.com

# ── Mac thumb-poll Bearer auth (per-user) ──────────────────────────
# Format: email1:secret1,email2:secret2
# Each Mac poller authenticates with its own Bearer; the email selects whose
# thumb queue rows it sees.
THUMB_QUEUE_USERS=

# ── Content doc storage ────────────────────────────────────────────
# Where /api/upload-content-doc writes files. Default: ../../content/content_docs
# CONTENT_DIR=/opt/content_docs/content_docs
